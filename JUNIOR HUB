-- FUNÇÃO DE ANIMAÇÃO
local function animar(objeto, propriedades, tempo, estilo)
    estilo = estilo or Enum.EasingStyle.Quad
    local tween = TweenService:Create(objeto, TweenInfo.new(tempo, estilo, Enum.EasingDirection.Out), propriedades)
    tween:Play()
    return tween
end

-- FUNÇÃO PARA CRIAR BOTÃO ARREDONDADO
local function criarBotao(parent, texto, posY, cor)
    local btn = Instance.new("TextButton")
    btn.Parent = parent
    btn.Size = UDim2.new(0.8, 0, 0, 55)
    btn.Position = UDim2.new(0.1, 0, posY, 0)
    btn.Text = texto
    btn.BackgroundColor3 = cor or cores.cinza
    btn.TextColor3 = cores.branco
    btn.TextSize = 18
    btn.Font = Enum.Font.GothamBold
    btn.BorderSizePixel = 0
    
    local corner = Instance.new("UICorner")
    corner.Parent = btn
    corner.CornerRadius = UDim.new(0, 15)
    
    -- ANIMAÇÃO HOVER
    btn.MouseEnter:Connect(function()
        animar(btn, {BackgroundColor3 = cores.cinzaClaro, Size = UDim2.new(0.82, 0, 0, 58)}, 0.2)
    end)
    
    btn.MouseLeave:Connect(function()
        animar(btn, {BackgroundColor3 = cor or cores.cinza, Size = UDim2.new(0.8, 0, 0, 55)}, 0.2)
    end)
    
    return btn
end

