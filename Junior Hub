-- FUNÇÃO PARA VALIDAR KEY
local function checkKey(key)
    local userId = tostring(player.UserId)
    local url = "https://store-key-system.onrender.com/check?key=" .. key .. "&userId=" .. userId
    
    local success, response = pcall(function()
        return game:HttpGet(url, true)
    end)
    
    if not success then
        return {valid = false, error = "Erro de conexão"}
    end
    
    return HttpService:JSONDecode(response)
end

-- CLIQUE DO BOTÃO
validateBtn.MouseButton1Click:Connect(function()
    local key = keyBox.Text
    if key == "" then
        statusText.Text = "Digite uma key!"
        statusText.TextColor3 = Color3.new(1,0.5,0)
        return
    end
    
    statusText.Text = "Validando..."
    statusText.TextColor3 = Color3.new(0.5,0.5,1)
    validateBtn.Visible = false
    
    task.spawn(function()
        local result = checkKey(key)
        
        if result and result.valid then
            getgenv().KEY_VALID = true
            statusText.Text = "KEY VALIDA! Aguarde..."
            statusText.TextColor3 = Color3.new(0,1,0)
            wait(1)
            screen:Destroy()
        else
            local msg = result and result.reason or "Key inválida!"
            if result and result.expired then msg = "KEY EXPIRADA!" end
            statusText.Text = msg
            statusText.TextColor3 = Color3.new(1,0,0)
            keyBox.Text = ""
            wait(2)
            statusText.Text = ""
            validateBtn.Visible = true
        end
    end)
end)

-- TRAVA ATÉ VALIDAR
