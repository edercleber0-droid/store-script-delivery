local function animar(objeto, propriedades, tempo, estilo)
    estilo = estilo or Enum.EasingStyle.Quad
    local tween = TweenService:Create(objeto, TweenInfo.new(tempo, estilo, Enum.EasingDirection.Out), propriedades)
    tween:Play()
    return tween
end

local function criarBotao(parent, texto, posY, cor)
    local btn = Instance.new("TextButton")
    btn.Parent = parent
    btn.Size = UDim2.new(0.8, 0, 0, 45)
    btn.Position = UDim2.new(0.1, 0, posY, 0)
    btn.Text = texto
    btn.BackgroundColor3 = cor or cores.cinza
    btn.TextColor3 = cores.branco
    btn.TextSize = 16
    btn.Font = Enum.Font.GothamBold
    btn.BorderSizePixel = 0
    
    local corner = Instance.new("UICorner")
    corner.Parent = btn
    corner.CornerRadius = UDim.new(0, 12)
    
    btn.MouseEnter:Connect(function()
        animar(btn, {BackgroundColor3 = cores.cinzaClaro, Size = UDim2.new(0.82, 0, 0, 48)}, 0.2)
    end)
    
    btn.MouseLeave:Connect(function()
        if btn.Ativado then
            animar(btn, {BackgroundColor3 = cores.verde, Size = UDim2.new(0.8, 0, 0, 45)}, 0.2)
        else
            animar(btn, {BackgroundColor3 = cor or cores.cinza, Size = UDim2.new(0.8, 0, 0, 45)}, 0.2)
        end
    end)
    
    return btn
end

