-- FUNÇÃO CONSULTAR RENDER
local function consultarRender(key)
    local userId = tostring(player.UserId)
    local url = "https://store-key-system.onrender.com/check?key=" .. key .. "&userId=" .. userId
    
    local success, response = pcall(function()
        return game:HttpGet(url, true)
    end)
    
    if not success then
        return nil, "Erro de conexão"
    end
    
    local decoded = HttpService:JSONDecode(response)
    return decoded, nil
end

local function verificarKey(key)
    local data, erro = consultarRender(key)
    
    if erro then
        return false, erro
    end
    
    if not data then
        return false, "Erro ao validar"
    end
    
    if not data.valid then
        if data.reason == "used_by_other_user" then
            return false, "KEY JÁ ESTÁ SENDO USADA!"
        end
        if data.expired then
            return false, "KEY EXPIRADA!"
        end
        return false, "KEY INVÁLIDA!"
    end
    
    local keyType = data.tipo or "perm"
    
    if keyType == "perm" then
        return true, "KEY PERMANENTE"
    end
    
    if data.expires then
        local agora = os.time() * 1000
        local diff = data.expires - agora
        
        if diff <= 0 then
            return false, "KEY EXPIRADA!"
        end
        
        local horas = math.floor(diff / (1000 * 60 * 60))
        local dias = math.floor(horas / 24)
        
        if keyType == "1d" then
            return true, "KEY 1 DIA - Expira em " .. dias .. " dia(s)"
        elseif keyType == "3d" then
            return true, "KEY 3 DIAS - Expira em " .. dias .. " dia(s)"
        else
            if horas < 24 then
                return true, "Expira em " .. horas .. " horas"
            else
                return true, "Expira em " .. dias .. " dias"
            end
        end
    end
    
    return true, "KEY VÁLIDA"
end

